<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <meta name="theme-color" content="#000000" />
    <title>Фитнес-дневник</title>
    <script src="https://telegram.org/js/telegram-web-app.js"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        }

        body {
            background: #000000;
            color: #ffffff;
            padding: 16px 16px 90px 16px;
            min-height: 100vh;
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 18px;
            padding-top: 6px;
        }

        .header h1 {
            font-size: 26px;
            font-weight: 700;
            color: #ffffff;
        }

        .header .date {
            font-size: 14px;
            color: #888888;
            background: #1a1a1a;
            padding: 4px 14px;
            border-radius: 20px;
            border: 1px solid #2a2a2a;
        }

        .tabs {
            display: flex;
            gap: 4px;
            background: #111111;
            border-radius: 12px;
            padding: 4px;
            margin-bottom: 16px;
            border: 1px solid #222222;
        }

        .tabs .tab {
            flex: 1;
            padding: 10px 0;
            text-align: center;
            border-radius: 10px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            color: #666666;
            background: transparent;
            border: none;
            transition: 0.2s;
        }

        .tabs .tab.active {
            background: #ffffff;
            color: #000000;
        }

        .card {
            background: #111111;
            border-radius: 14px;
            padding: 16px;
            margin-bottom: 12px;
            border: 1px solid #222222;
        }

        .card-title {
            font-size: 16px;
            font-weight: 600;
            margin-bottom: 12px;
            color: #ffffff;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .card-title .badge {
            font-size: 13px;
            color: #888888;
            background: #1a1a1a;
            padding: 2px 12px;
            border-radius: 12px;
            border: 1px solid #2a2a2a;
        }

        .big-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
        }

        .big-btn {
            background: #1a1a1a;
            border-radius: 14px;
            padding: 20px 10px;
            text-align: center;
            cursor: pointer;
            border: 2px solid transparent;
            transition: 0.2s;
            user-select: none;
            touch-action: manipulation;
        }

        .big-btn:active {
            transform: scale(0.95);
        }

        .big-btn.active {
            border-color: #ffffff;
            background: #222222;
        }

        .big-btn .icon {
            font-size: 36px;
            display: block;
            margin-bottom: 4px;
        }

        .big-btn .label {
            font-size: 13px;
            color: #888888;
        }

        .big-btn .value {
            font-size: 22px;
            font-weight: 700;
            margin-top: 2px;
            color: #ffffff;
        }

        .big-btn .hint {
            font-size: 10px;
            color: #444444;
            margin-top: 4px;
        }

        .progress-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 10px;
        }

        .progress-row .label {
            color: #888888;
            font-size: 14px;
        }

        .progress-row .percent {
            color: #ffffff;
            font-weight: 600;
            font-size: 14px;
        }

        .progress-bar {
            background: #1a1a1a;
            border-radius: 6px;
            height: 6px;
            margin-top: 6px;
            overflow: hidden;
            border: 1px solid #2a2a2a;
        }

        .progress-bar .fill {
            background: #ffffff;
            height: 100%;
            border-radius: 6px;
            transition: width 0.5s ease;
            width: 0%;
        }

        .ex-item {
            display: flex;
            align-items: center;
            padding: 10px 0;
            border-bottom: 1px solid #1a1a1a;
            gap: 14px;
        }

        .ex-item:last-child {
            border-bottom: none;
        }

        .ex-item .check {
            width: 32px;
            height: 32px;
            min-width: 32px;
            border-radius: 50%;
            border: 2px solid #444444;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: 18px;
            transition: 0.2s;
        }

        .ex-item .check.done {
            border-color: #4ade80;
            background: #4ade80;
            color: #000000;
        }

        .ex-item .info {
            flex: 1;
        }

        .ex-item .info .name {
            font-size: 16px;
            font-weight: 500;
            color: #ffffff;
        }

        .ex-item .info .details {
            font-size: 13px;
            color: #666666;
        }

        .ex-item .info .details.done-text {
            color: #4ade80;
        }

        .empty {
            color: #555555;
            text-align: center;
            padding: 24px 0;
            font-size: 14px;
            line-height: 1.6;
        }

        .day-selector {
            display: flex;
            gap: 6px;
            margin-bottom: 16px;
            flex-wrap: wrap;
        }

        .day-btn {
            flex: 1;
            min-width: 36px;
            padding: 10px 0;
            text-align: center;
            border-radius: 10px;
            background: #1a1a1a;
            border: 2px solid #2a2a2a;
            color: #666666;
            font-weight: 600;
            font-size: 13px;
            cursor: pointer;
            transition: 0.2s;
            user-select: none;
        }

        .day-btn.active {
            border-color: #ffffff;
            background: #ffffff;
            color: #000000;
        }

        .day-btn.training-day {
            border-color: #4ade80;
            background: #0d1a12;
            color: #4ade80;
        }

        .day-btn.training-day.active {
            border-color: #ffffff;
            background: #ffffff;
            color: #000000;
        }

        .day-btn:active {
            transform: scale(0.95);
        }

        .ex-row {
            display: flex;
            gap: 8px;
            align-items: center;
            padding: 6px 0;
            border-bottom: 1px solid #1a1a1a;
        }

        .ex-row:last-child {
            border-bottom: none;
        }

        .ex-row .num {
            color: #444444;
            font-size: 13px;
            font-weight: 600;
            min-width: 24px;
        }

        .ex-row input {
            background: #1a1a1a;
            border: 1px solid #2a2a2a;
            border-radius: 8px;
            padding: 6px 8px;
            color: #ffffff;
            font-size: 14px;
            outline: none;
            transition: 0.2s;
        }

        .ex-row input:focus {
            border-color: #ffffff;
        }

        .ex-row input.name {
            flex: 1;
        }

        .ex-row input.num-input {
            width: 42px;
            text-align: center;
        }

        .ex-row input::placeholder {
            color: #444446;
            font-size: 12px;
        }

        .ex-row .del {
            color: #555555;
            font-size: 18px;
            cursor: pointer;
            background: none;
            border: none;
            padding: 0 4px;
        }

        .ex-row .del:hover {
            color: #ff4444;
        }

        .add-ex-btn {
            width: 100%;
            padding: 10px 0;
            margin-top: 8px;
            background: transparent;
            border: 1px dashed #333333;
            border-radius: 10px;
            color: #666666;
            font-size: 14px;
            cursor: pointer;
            transition: 0.2s;
        }

        .add-ex-btn:hover {
            border-color: #666666;
            color: #aaaaaa;
        }

        .btn {
            padding: 12px 20px;
            border: none;
            border-radius: 10px;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            transition: 0.2s;
        }

        .btn:active {
            transform: scale(0.95);
        }

        .btn-white {
            background: #ffffff;
            color: #000000;
        }

        .btn-white:hover {
            background: #eeeeee;
        }

        .btn-danger {
            background: #333333;
            color: #ffffff;
        }

        .btn-danger:hover {
            background: #444444;
        }

        .btn-small {
            padding: 4px 14px;
            font-size: 12px;
            border-radius: 8px;
        }

        .stat-grid {
            display: grid;
            grid-template-columns: 1fr 1fr 1fr;
            gap: 8px;
        }

        .stat-box {
            background: #1a1a1a;
            border-radius: 12px;
            padding: 14px 6px;
            text-align: center;
            border: 1px solid #2a2a2a;
        }

        .stat-box .num {
            font-size: 24px;
            font-weight: 700;
            color: #ffffff;
        }

        .stat-box .lbl {
            font-size: 11px;
            color: #666666;
            margin-top: 2px;
        }

        .history-day {
            margin-bottom: 14px;
        }

        .history-day .hd {
            font-size: 14px;
            font-weight: 600;
            color: #ffffff;
            padding: 6px 0;
            border-bottom: 1px solid #2a2a2a;
            margin-bottom: 4px;
        }

        .history-day .hd .date {
            color: #888888;
            font-weight: 400;
            font-size: 12px;
        }

        .history-ex {
            display: flex;
            justify-content: space-between;
            padding: 4px 0 4px 8px;
            border-left: 2px solid #444444;
            margin-bottom: 2px;
        }

        .history-ex .name {
            font-size: 14px;
            color: #dddddd;
        }

        .history-ex .meta {
            font-size: 12px;
            color: #666666;
        }

        .hidden {
            display: none !important;
        }

        ::-webkit-scrollbar {
            width: 3px;
        }
        ::-webkit-scrollbar-track {
            background: #111111;
        }
        ::-webkit-scrollbar-thumb {
            background: #444444;
            border-radius: 3px;
        }

        input[type="number"]::-webkit-inner-spin-button,
        input[type="number"]::-webkit-outer-spin-button {
            -webkit-appearance: none;
        }
        input[type="number"] {
            -moz-appearance: textfield;
        }
    </style>
</head>
<body>

    <div class="header">
        <h1>🏋️ Дневник</h1>
        <span class="date" id="todayDate"></span>
    </div>

    <div class="tabs" id="mainTabs">
        <button class="tab active" data-tab="today">Сегодня</button>
        <button class="tab" data-tab="program">Программа</button>
        <button class="tab" data-tab="stats">Статистика</button>
        <button class="tab" data-tab="history">История</button>
    </div>

    <div id="tab-today">
        <div class="card">
            <div class="card-title">
                <span>📅 Сегодня</span>
                <span class="badge" id="todayProgress">0%</span>
            </div>
            <div class="big-grid">
                <div class="big-btn" id="gymToggle">
                    <span class="icon">🏋️</span>
                    <span class="label">Зал</span>
                    <span class="value" id="gymStatus">❌</span>
                </div>
                <div class="big-btn" id="waterToggle">
                    <span class="icon">💧</span>
                    <span class="label">Вода</span>
                    <span class="value" id="waterStatus">0 л</span>
                    <span class="hint">👆 добавить · 👆👆 убрать</span>
                </div>
            </div>
            <div class="progress-row">
                <span class="label">Активность</span>
                <span class="percent" id="activityPercent">0%</span>
            </div>
            <div class="progress-bar">
                <div class="fill" id="activityBar"></div>
            </div>
        </div>

        <div class="card">
            <div class="card-title">
                <span id="todayWorkoutTitle">💪 Тренировка</span>
                <span class="badge" id="todayWorkoutCount">0 из 0</span>
            </div>
            <div id="todayWorkoutList">
                <div class="empty">Нет упражнений<br>Добавь в «Программа»</div>
            </div>
        </div>
    </div>

    <div id="tab-program" class="hidden">
        <div class="card">
            <div class="card-title">
                <span>📋 Программа</span>
                <span class="badge" id="programTotal">0 упр.</span>
            </div>

            <div style="margin-bottom:12px;">
                <div style="color:#888888;font-size:13px;margin-bottom:6px;">👇 Нажми на день, чтобы добавить/убрать его из плана</div>
                <div class="day-selector" id="trainingDaysSelector">
                    <div class="day-btn" data-day="1">ПН</div>
                    <div class="day-btn" data-day="2">ВТ</div>
                    <div class="day-btn" data-day="3">СР</div>
                    <div class="day-btn" data-day="4">ЧТ</div>
                    <div class="day-btn" data-day="5">ПТ</div>
                    <div class="day-btn" data-day="6">СБ</div>
                    <div class="day-btn" data-day="0">ВС</div>
                </div>
                <div style="margin-top:6px;font-size:13px;color:#4ade80;" id="selectedDaysDisplay">Выбрано: ПН, СР, ПТ</div>
            </div>

            <hr style="border-color:#2a2a2a;margin-bottom:12px;" />

            <div style="color:#888888;font-size:13px;margin-bottom:6px;">📝 Выбери день для редактирования упражнений</div>
            <div class="day-selector" id="editDaySelector">
                <div class="day-btn" data-day="1">ПН</div>
                <div class="day-btn" data-day="2">ВТ</div>
                <div class="day-btn" data-day="3">СР</div>
                <div class="day-btn" data-day="4">ЧТ</div>
                <div class="day-btn" data-day="5">ПТ</div>
                <div class="day-btn" data-day="6">СБ</div>
                <div class="day-btn" data-day="0">ВС</div>
            </div>

            <div id="programEditor" style="margin-top:12px;"></div>

            <button class="add-ex-btn" id="addExerciseBtn">+ Добавить упражнение</button>
            <button class="btn btn-white" id="saveProgramBtn" style="width:100%;margin-top:12px;">💾 Сохранить</button>
        </div>
    </div>

    <div id="tab-stats" class="hidden">
        <div class="card">
            <div class="card-title">📊 Посещаемость</div>
            <div class="stat-grid">
                <div class="stat-box"><div class="num" id="plannedDays">0</div><div class="lbl">Планировал</div></div>
                <div class="stat-box"><div class="num" id="completedDays">0</div><div class="lbl">Сходил</div></div>
                <div class="stat-box"><div class="num" id="percentDays">0%</div><div class="lbl">Выполнено</div></div>
            </div>
        </div>

        <div class="card">
            <div class="card-title">📊 За неделю</div>
            <div class="stat-grid">
                <div class="stat-box"><div class="num" id="weekWorkouts">0</div><div class="lbl">Упражнений</div></div>
                <div class="stat-box"><div class="num" id="weekDays">0</div><div class="lbl">Дней</div></div>
                <div class="stat-box"><div class="num" id="totalWorkouts">0</div><div class="lbl">В зале</div></div>
            </div>
        </div>

        <div class="card">
            <div class="card-title">🏆 Всего</div>
            <div class="stat-grid">
                <div class="stat-box"><div class="num" id="totalAttendance">0%</div><div class="lbl">Посещаемость</div></div>
                <div class="stat-box"><div class="num" id="totalWorkoutsAll">0</div><div class="lbl">Упражнений</div></div>
                <div class="stat-box"><div class="num" id="totalDays">0</div><div class="lbl">Дней в зале</div></div>
            </div>
        </div>
    </div>

    <div id="tab-history" class="hidden">
        <div class="card">
            <div class="card-title">
                <span>📜 История</span>
                <button class="btn btn-danger btn-small" id="clearHistoryBtn">Очистить</button>
            </div>
            <div id="historyList">
                <div class="empty">Нет записей</div>
            </div>
        </div>
    </div>

    <script>
        const tg = window.Telegram?.WebApp || null;
        if (tg) {
            tg.ready();
            tg.expand();
            tg.setHeaderColor('#000000');
            tg.setBackgroundColor('#000000');
        }

        const STORAGE_KEY = 'fitness_diary_v18';

        function getDefaultData() {
            return {
                program: { 0: [], 1: [], 2: [], 3: [], 4: [], 5: [], 6: [] },
                completed: {},
                gymDays: [],
                waterLog: {},
                plannedDays: [1, 3, 5]
            };
        }

        function loadData() {
            try {
                const raw = localStorage.getItem(STORAGE_KEY);
                if (raw) {
                    const data = JSON.parse(raw);
                    const def = getDefaultData();
                    for (const k in def) {
                        if (!(k in data)) data[k] = def[k];
                    }
                    for (let i = 0; i <= 6; i++) {
                        if (!(i in data.program)) data.program[i] = [];
                    }
                    return data;
                }
            } catch (e) { console.warn('Ошибка загрузки', e); }
            return getDefaultData();
        }

        function saveData() {
            try {
                localStorage.setItem(STORAGE_KEY, JSON.stringify(data));
            } catch (e) { console.warn('Ошибка сохранения', e); }
        }

        let data = loadData();

        function formatDateLocal(date) {
            const y = date.getFullYear();
            const m = String(date.getMonth() + 1).padStart(2, '0');
            const d = String(date.getDate()).padStart(2, '0');
            return `${y}-${m}-${d}`;
        }

        function today() {
            return formatDateLocal(new Date());
        }

        function getDayOfWeek(dateStr) {
            return new Date(dateStr + 'T00:00:00').getDay();
        }

        function getWeekDates() {
            const now = new Date();
            const dow = now.getDay();
            const offset = dow === 0 ? 6 : dow - 1;
            const mon = new Date(now);
            mon.setDate(now.getDate() - offset);
            const dates = [];
            for (let i = 0; i < 7; i++) {
                const d = new Date(mon);
                d.setDate(mon.getDate() + i);
                dates.push(formatDateLocal(d));
            }
            return dates;
        }

        function formatDate(d) {
            const date = new Date(d + 'T00:00:00');
            return date.toLocaleDateString('ru-RU', { day: '2-digit', month: 'short' });
        }

        function formatDateFull(d) {
            const date = new Date(d + 'T00:00:00');
            return date.toLocaleDateString('ru-RU', { weekday: 'long', day: '2-digit', month: 'long' });
        }

        function getDayNameFull(dayIndex) {
            const names = ['Воскресенье', 'Понедельник', 'Вторник', 'Среда', 'Четверг', 'Пятница', 'Суббота'];
            return names[dayIndex] || '';
        }

        function generateId() {
            return Date.now() + '_' + Math.random().toString(36).slice(2, 6);
        }

        function escapeHtml(str) {
            return String(str)
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#39;');
        }

        function getTotalProgramExercises() {
            let total = 0;
            for (let i = 0; i <= 6; i++) {
                total += (data.program[i] || []).length;
            }
            return total;
        }

        function updateProgramTotalBadge() {
            const total = getTotalProgramExercises();
            document.getElementById('programTotal').textContent = total + ' упр.';
        }

        function calculateAttendance() {
            const weekDates = getWeekDates();
            const todayStr = today();
            const planned = data.plannedDays.length;
            let completed = 0;
            for (const d of weekDates) {
                if (d > todayStr) continue;
                const dow = getDayOfWeek(d);
                if (data.plannedDays.includes(dow) && data.gymDays.includes(d)) {
                    completed++;
                }
            }
            return {
                planned,
                completed,
                percent: planned > 0 ? Math.round((completed / planned) * 100) : 0
            };
        }

        function calculateTotalAttendance() {
            if (data.gymDays.length === 0) return 0;
            const weeklyPlan = data.plannedDays.length;
            if (weeklyPlan === 0) return 0;

            let totalPlanned = 0;
            let totalCompleted = 0;
            const sorted = data.gymDays.slice().sort();
            const first = new Date(sorted[0] + 'T00:00:00');
            const now = new Date();
            const todayStr = today();
            let monday = new Date(first);
            let dow = monday.getDay();
            const offset = dow === 0 ? 6 : dow - 1;
            monday.setDate(monday.getDate() - offset);

            while (monday <= now) {
                const week = [];
                for (let i = 0; i < 7; i++) {
                    const d = new Date(monday);
                    d.setDate(monday.getDate() + i);
                    week.push(formatDateLocal(d));
                }
                let completed = 0;
                for (const d of week) {
                    if (d > todayStr) continue;
                    const dow2 = getDayOfWeek(d);
                    if (data.plannedDays.includes(dow2) && data.gymDays.includes(d)) {
                        completed++;
                    }
                }
                totalPlanned += weeklyPlan;
                totalCompleted += completed;
                const next = new Date(monday);
                next.setDate(monday.getDate() + 7);
                monday = next;
            }
            return totalPlanned > 0 ? Math.round((totalCompleted / totalPlanned) * 100) : 0;
        }

        let currentEditDay = 1;

        function renderAll() {
            renderToday();
            renderTodayWorkout();
            renderProgram();
            renderStats();
            renderHistory();
            renderTrainingDays();
        }

        function renderToday() {
            document.getElementById('todayDate').textContent = new Date().toLocaleDateString('ru-RU', {
                weekday: 'short', day: '2-digit', month: 'short'
            });

            const d = today();
            const gym = data.gymDays.includes(d);
            document.getElementById('gymStatus').textContent = gym ? '✅' : '❌';
            document.getElementById('gymToggle').classList.toggle('active', gym);

            const water = data.waterLog[d] || 0;
            document.getElementById('waterStatus').textContent = (water / 1000).toFixed(1) + ' л';
            document.getElementById('waterToggle').classList.toggle('active', water > 0);

            let points = 0;
            if (gym) points++;
            if (water >= 2000) points++;
            else if (water > 0) points += 0.5;

            const todayExercises = getTodayExercises();
            const todayCompleted = getTodayCompleted();
            if (todayExercises.length > 0) {
                const done = todayExercises.filter(ex => todayCompleted.includes(ex.id)).length;
                if (done === todayExercises.length) points++;
                else if (done > 0) points += 0.5;
            }

            const pct = Math.min(100, Math.round((points / 3) * 100));
            document.getElementById('activityPercent').textContent = pct + '%';
            document.getElementById('activityBar').style.width = pct + '%';

            const att = calculateAttendance();
            document.getElementById('todayProgress').textContent = '🔥 ' + att.percent + '%';
        }

        function getTodayExercises() {
            const dow = getDayOfWeek(today());
            return data.program[dow] || [];
        }

        function getTodayCompleted() {
            const d = today();
            if (!data.completed[d]) data.completed[d] = [];
            return data.completed[d];
        }

        function toggleExercise(exId) {
            const d = today();
            if (!data.completed[d]) data.completed[d] = [];
            const idx = data.completed[d].indexOf(exId);
            if (idx === -1) data.completed[d].push(exId);
            else data.completed[d].splice(idx, 1);
            saveData();
            renderTodayWorkout();
            renderToday();
            renderStats();
        }

        function renderTodayWorkout() {
            const exercises = getTodayExercises();
            const completed = getTodayCompleted();
            const container = document.getElementById('todayWorkoutList');
            const countEl = document.getElementById('todayWorkoutCount');
            const titleEl = document.getElementById('todayWorkoutTitle');

            const dayName = getDayNameFull(getDayOfWeek(today()));
            titleEl.textContent = '💪 ' + dayName;

            if (exercises.length === 0) {
                container.innerHTML = '<div class="empty">Нет упражнений на сегодня<br>Добавь в «Программа»</div>';
                countEl.textContent = '0 из 0';
                return;
            }

            const done = exercises.filter(ex => completed.includes(ex.id)).length;
            countEl.textContent = done + ' из ' + exercises.length;

            container.innerHTML = exercises.map(ex => {
                const isDone = completed.includes(ex.id);
                return `
                    <div class="ex-item">
                        <div class="check ${isDone ? 'done' : ''}" data-ex-id="${escapeHtml(ex.id)}">
                            ${isDone ? '✓' : ''}
                        </div>
                        <div class="info">
                            <div class="name">${escapeHtml(ex.name)}</div>
                            <div class="details ${isDone ? 'done-text' : ''}">
                                ${escapeHtml(ex.sets || '—')} × ${escapeHtml(ex.reps || '—')} · ${escapeHtml(ex.weight || '—')} кг
                            </div>
                        </div>
                    </div>
                `;
            }).join('');
        }

        function renderProgram() {
            renderTrainingDays();
            renderEditDays();
            renderProgramExercises(currentEditDay);
            updateProgramTotalBadge();
        }

        function renderTrainingDays() {
            const container = document.getElementById('trainingDaysSelector');
            const btns = container.querySelectorAll('.day-btn');
            btns.forEach(btn => {
                const day = parseInt(btn.dataset.day, 10);
                const isPlanned = data.plannedDays.includes(day);
                btn.classList.toggle('active', isPlanned);
                btn.classList.toggle('training-day', isPlanned);
            });

            const names = ['ВС', 'ПН', 'ВТ', 'СР', 'ЧТ', 'ПТ', 'СБ'];
            const sorted = [...data.plannedDays].sort((a, b) => a - b);
            const display = sorted.map(d => names[d]).join(', ');
            document.getElementById('selectedDaysDisplay').textContent = 'Выбрано: ' + (display || 'не выбрано');
        }

        function renderEditDays() {
            const container = document.getElementById('editDaySelector');
            const btns = container.querySelectorAll('.day-btn');
            btns.forEach(btn => {
                const day = parseInt(btn.dataset.day, 10);
                btn.classList.toggle('active', day === currentEditDay);
            });
        }

        function renderProgramExercises(dayIdx) {
            const container = document.getElementById('programEditor');
            const exercises = data.program[dayIdx] || [];

            if (exercises.length === 0) {
                container.innerHTML = '<div style="color:#555555;text-align:center;padding:16px 0;">Нет упражнений</div>';
                updateProgramTotalBadge();
                return;
            }

            let html = '';
            exercises.forEach((ex, idx) => {
                html += `
                    <div class="ex-row">
                        <span class="num">${idx + 1}</span>
                        <input class="name" type="text" value="${escapeHtml(ex.name)}" placeholder="Упражнение" data-day="${dayIdx}" data-idx="${idx}" data-field="name" />
                        <input class="num-input" type="number" value="${escapeHtml(ex.sets || '')}" placeholder="Х" data-day="${dayIdx}" data-idx="${idx}" data-field="sets" />
                        <input class="num-input" type="number" value="${escapeHtml(ex.reps || '')}" placeholder="П" data-day="${dayIdx}" data-idx="${idx}" data-field="reps" />
                        <input class="num-input" type="number" value="${escapeHtml(ex.weight || '')}" placeholder="В" data-day="${dayIdx}" data-idx="${idx}" data-field="weight" />
                        <button class="del" data-day="${dayIdx}" data-idx="${idx}">✕</button>
                    </div>
                `;
            });

            container.innerHTML = html;
            updateProgramTotalBadge();

            container.querySelectorAll('input').forEach(inp => {
                inp.addEventListener('change', function() {
                    const d = parseInt(this.dataset.day, 10);
                    const idx = parseInt(this.dataset.idx, 10);
                    const field = this.dataset.field;
                    if (data.program[d] && data.program[d][idx]) {
                        data.program[d][idx][field] = this.value;
                        saveData();
                    }
                });
            });

            container.querySelectorAll('.del').forEach(btn => {
                btn.addEventListener('click', function() {
                    const d = parseInt(this.dataset.day, 10);
                    const idx = parseInt(this.dataset.idx, 10);
                    if (data.program[d]) {
                        data.program[d].splice(idx, 1);
                        saveData();
                        renderProgramExercises(d);
                        renderTodayWorkout();
                        renderStats();
                    }
                });
            });
        }

        document.querySelectorAll('#trainingDaysSelector .day-btn').forEach(btn => {
            btn.addEventListener('click', function() {
                const day = parseInt(this.dataset.day, 10);
                const idx = data.plannedDays.indexOf(day);
                if (idx === -1) {
                    if (data.plannedDays.length < 7) {
                        data.plannedDays.push(day);
                        data.plannedDays.sort((a, b) => a - b);
                    } else {
                        alert('Все дни уже выбраны');
                        return;
                    }
                } else {
                    if (data.plannedDays.length > 1) {
                        data.plannedDays.splice(idx, 1);
                    } else {
                        alert('Выбери хотя бы один день');
                        return;
                    }
                }
                saveData();
                renderTrainingDays();
                renderToday();
                renderStats();
            });
        });

        document.querySelectorAll('#editDaySelector .day-btn').forEach(btn => {
            btn.addEventListener('click', function() {
                currentEditDay = parseInt(this.dataset.day, 10);
                renderProgram();
            });
        });

        document.getElementById('addExerciseBtn').addEventListener('click', function() {
            if (!data.program[currentEditDay]) data.program[currentEditDay] = [];
            data.program[currentEditDay].push({ id: generateId(), name: '', sets: '', reps: '', weight: '' });
            saveData();
            renderProgramExercises(currentEditDay);
            renderTodayWorkout();
            renderStats();
        });

        document.getElementById('saveProgramBtn').addEventListener('click', function() {
            saveData();
            renderAll();
            alert('✅ Сохранено!');
        });

        function renderStats() {
            const week = getWeekDates();
            const todayStr = today();
            let allWorkouts = [];
            week.forEach(d => {
                if (d > todayStr) return;
                if (data.completed[d]) {
                    const dow = getDayOfWeek(d);
                    const program = data.program[dow] || [];
                    const completedIds = data.completed[d] || [];
                    program.forEach(ex => {
                        if (completedIds.includes(ex.id)) allWorkouts.push({ date: d, exercise: ex });
                    });
                }
            });

            const att = calculateAttendance();
            document.getElementById('plannedDays').textContent = att.planned;
            document.getElementById('completedDays').textContent = att.completed;
            document.getElementById('percentDays').textContent = att.percent + '%';
            document.getElementById('weekWorkouts').textContent = allWorkouts.length;
            document.getElementById('weekDays').textContent = new Set(allWorkouts.map(w => w.date)).size;

            const weekGymDays = week.filter(d => d <= todayStr && data.gymDays.includes(d)).length;
            document.getElementById('totalWorkouts').textContent = weekGymDays;

            let total = 0;
            for (const key in data.completed) total += data.completed[key].length;
            document.getElementById('totalWorkoutsAll').textContent = total;
            document.getElementById('totalAttendance').textContent = calculateTotalAttendance() + '%';
            document.getElementById('totalDays').textContent = data.gymDays.length;
        }

        function renderHistory() {
            const container = document.getElementById('historyList');
            const groups = {};

            for (const key in data.completed) {
                const dow = getDayOfWeek(key);
                const program = data.program[dow] || [];
                const completedIds = data.completed[key] || [];
                const exercises = program.filter(ex => completedIds.includes(ex.id));
                if (exercises.length > 0) groups[key] = exercises;
            }

            const sorted = Object.keys(groups).sort((a, b) => b.localeCompare(a));

            if (sorted.length === 0) {
                container.innerHTML = '<div class="empty">Нет записей</div>';
                return;
            }

            let html = '';
            sorted.forEach(date => {
                const exercises = groups[date];
                const isToday = date === today();
                html += `
                    <div class="history-day">
                        <div class="hd">
                            ${isToday ? '⭐ ' : ''}${escapeHtml(formatDateFull(date))}
                            <span class="date">${escapeHtml(formatDate(date))}</span>
                            <span style="float:right;color:#555;font-weight:400;font-size:12px;">${exercises.length} упр.</span>
                        </div>
                `;
                exercises.forEach(ex => {
                    html += `
                        <div class="history-ex">
                            <span class="name">${escapeHtml(ex.name)}</span>
                            <span class="meta">${escapeHtml(ex.sets || '—')}×${escapeHtml(ex.reps || '—')} · ${escapeHtml(ex.weight || '—')} кг ✅</span>
                        </div>
                    `;
                });
                html += `</div>`;
            });

            container.innerHTML = html;
        }

        document.getElementById('gymToggle').addEventListener('click', function() {
            const d = today();
            const idx = data.gymDays.indexOf(d);
            if (idx === -1) data.gymDays.push(d);
            else data.gymDays.splice(idx, 1);
            saveData();
            renderAll();
        });

        let waterTimer = null;
        let isTouchDevice = false;
        const wt = document.getElementById('waterToggle');

        function addWater() {
            const d = today();
            if (!data.waterLog[d]) data.waterLog[d] = 0;
            data.waterLog[d] = Math.min(5000, data.waterLog[d] + 500);
            saveData();
            renderAll();
        }

        function removeWater() {
            const d = today();
            if (!data.waterLog[d]) data.waterLog[d] = 0;
            if (data.waterLog[d] > 0) {
                data.waterLog[d] = Math.max(0, data.waterLog[d] - 500);
                if (data.waterLog[d] === 0) delete data.waterLog[d];
                saveData();
                renderAll();
                if (navigator.vibrate) navigator.vibrate(30);
            }
        }

        function startWaterLongPress() {
            waterTimer = setTimeout(() => {
                waterTimer = null;
                removeWater();
            }, 500);
        }

        function cancelWaterLongPress() {
            if (waterTimer) {
                clearTimeout(waterTimer);
                waterTimer = null;
                return true;
            }
            return false;
        }

        wt.addEventListener('touchstart', function(e) {
            isTouchDevice = true;
            e.preventDefault();
            startWaterLongPress();
        }, { passive: false });

        wt.addEventListener('touchend', function() {
            if (cancelWaterLongPress()) addWater();
            setTimeout(() => { isTouchDevice = false; }, 300);
        });

        wt.addEventListener('touchcancel', function() {
            cancelWaterLongPress();
            setTimeout(() => { isTouchDevice = false; }, 300);
        });

        wt.addEventListener('mousedown', function(e) {
            if (isTouchDevice) return;
            e.preventDefault();
            startWaterLongPress();
        });

        wt.addEventListener('mouseup', function() {
            if (isTouchDevice) return;
            if (cancelWaterLongPress()) addWater();
        });

        wt.addEventListener('mouseleave', function() {
            if (isTouchDevice) return;
            cancelWaterLongPress();
        });

        document.getElementById('todayWorkoutList').addEventListener('click', function(e) {
            const check = e.target.closest('.check[data-ex-id]');
            if (!check) return;
            toggleExercise(check.dataset.exId);
        });

        document.querySelectorAll('.tab').forEach(t => {
            t.addEventListener('click', function() {
                document.querySelectorAll('.tab').forEach(x => x.classList.remove('active'));
                this.classList.add('active');
                const target = this.dataset.tab;
                document.querySelectorAll('[id^="tab-"]').forEach(el => el.classList.add('hidden'));
                document.getElementById('tab-' + target).classList.remove('hidden');
                if (target === 'program') renderProgram();
                if (target === 'history') renderHistory();
                if (target === 'stats') renderStats();
            });
        });

        document.getElementById('clearHistoryBtn').addEventListener('click', function() {
            if (confirm('Удалить всю историю (тренировки, зал, вода)?')) {
                data.completed = {};
                data.gymDays = [];
                data.waterLog = {};
                saveData();
                renderAll();
            }
        });

        renderAll();
        window.addEventListener('beforeunload', saveData);

        console.log('💪 Фитнес-дневник загружен!');
    </script>

</body>
</html>
